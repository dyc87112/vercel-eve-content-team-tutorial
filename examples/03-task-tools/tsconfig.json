{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "eve/tools": ["./node_modules/eve/dist/src/public/tools/index.d.ts"],
      "eve/tools/approval": ["./node_modules/eve/dist/src/public/tools/approval/index.d.ts"],
      "eve/sandbox": ["./node_modules/eve/dist/src/public/sandbox/index.d.ts"],
      "eve/sandbox/just-bash": ["./node_modules/eve/dist/src/public/sandbox/just-bash.d.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".eve/**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
