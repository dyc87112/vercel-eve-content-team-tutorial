# 当前 agent/agent.ts 使用字符串模型 ID，因此默认通过 Vercel AI Gateway。
# 在 https://vercel.com/dashboard/ai/api-keys 创建 Key，然后填写到 .env.local。
AI_GATEWAY_API_KEY=

# 也可以运行 `npm exec -- eve link`，由 Eve 写入 VERCEL_OIDC_TOKEN。
# VERCEL_OIDC_TOKEN=

# 下面的变量只有在 agent/agent.ts 改为对应 AI SDK Provider 后才会生效。
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# 自定义 OpenAI-compatible Provider 可约定使用这些变量。
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
